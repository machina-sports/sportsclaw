# K8s overlays — only the public `example/` overlay is versioned. Customer- or
# environment-specific overlays (e.g. `sportsclaw-machina/`) stay local: they
# tend to carry internal hostnames, image tags, and a sibling secrets.env.
docker/relay/k8s/overlays/*/
!docker/relay/k8s/overlays/example/
# Defense-in-depth: secrets.env never enters the index, even if a new overlay
# directory is later un-ignored.
docker/relay/k8s/overlays/*/secrets.env
!docker/relay/k8s/overlays/example/secrets.env
.vscode/settings.json
package-lock.json

# VitePress docs build artifacts + CI staging into the site image
docs/.vitepress/dist/
docs/.vitepress/cache/
site/docs/
.gstack/

# Staged from scripts/install.sh by build-site.yml at deploy time
docs/public/install.sh
site/html/
